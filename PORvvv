<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<title>Deobfuscator Tool</title>
<style>
    body {
        font-family: Arial;
        background: #0f172a;
        color: white;
        text-align: center;
        padding: 20px;
    }
    textarea {
        width: 90%;
        height: 200px;
        margin: 10px;
        border-radius: 10px;
        padding: 10px;
        border: none;
    }
    button {
        padding: 10px 20px;
        border-radius: 10px;
        border: none;
        background: #22c55e;
        color: white;
        cursor: pointer;
        margin: 5px;
    }
</style>
</head>
<body>

<h2>🔓 Auto Deobfuscator</h2>

<textarea id="input" placeholder="Dán code bị mã hóa vào đây..."></textarea><br>

<button onclick="decodeBase64()">Giải mã Base64</button>
<button onclick="runEval()">Chạy Eval</button>
<button onclick="beautify()">Làm đẹp code</button>

<textarea id="output" placeholder="Code sau khi giải mã..."></textarea>

<script>
// Base64 decode
function decodeBase64() {
    try {
        let input = document.getElementById("input").value;
        let decoded = atob(input);
        document.getElementById("output").value = decoded;
    } catch(e) {
        alert("Không phải Base64!");
    }
}

// Eval decode (cẩn thận)
function runEval() {
    try {
        let input = document.getElementById("input").value;
        let result = eval(input);
        document.getElementById("output").value = result || input;
    } catch(e) {
        alert("Không chạy được eval!");
    }
}

// Beautify đơn giản
function beautify() {
    let code = document.getElementById("input").value;
    let formatted = code
        .replace(/;/g, ";\n")
        .replace(/{/g, "{\n")
        .replace(/}/g, "\n}");
    document.getElementById("output").value = formatted;
}
</script>

</body>
</html>